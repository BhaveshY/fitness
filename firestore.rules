rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable) - User ID
    //   - dietPlan: string (optional) - JSON stringified diet plan
    //   - workoutPlan: string (optional) - JSON stringified workout plan
    //   - progress: string (optional) - JSON stringified progress array
    //   - dailyTracking: string (optional) - JSON stringified daily tracking record
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'dietPlan', 'workoutPlan', 'progress', 'dailyTracking']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             (!('dietPlan' in data) || (data.dietPlan is string && data.dietPlan.size() < 1000000)) &&
             (!('workoutPlan' in data) || (data.workoutPlan is string && data.workoutPlan.size() < 1000000)) &&
             (!('progress' in data) || (data.progress is string && data.progress.size() < 1000000)) &&
             (!('dailyTracking' in data) || (data.dailyTracking is string && data.dailyTracking.size() < 1000000));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified();
      allow delete: if isOwner(userId);
    }
  }
}
